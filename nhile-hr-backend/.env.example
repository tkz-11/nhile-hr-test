# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # Chỉ dùng ở backend, không expose ra client

# Database (lấy từ Supabase → Settings → Database)
DATABASE_URL=postgresql+asyncpg://postgres:[password]@db.[project].supabase.co:5432/postgres

# App
SECRET_KEY=your-random-secret-key-min-32-chars
ENVIRONMENT=development  # hoặc production

# AI (Google Gemini — cho AI Insights)
GEMINI_API_KEY=your-gemini-key

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://nhile-hr.railway.app
